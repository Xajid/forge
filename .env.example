# ============================================
# Forge - Environment Variables
# ============================================

# Turso Database (libSQL)
# DATABASE_URL - Pooled connection (use in production on Vercel)
# Format: libsql://forge-db-username.turso.io?authToken=your-token
DATABASE_URL="libsql://forge-db-YOURORG.turso.io?authToken=YOUR_TOKEN"

# DIRECT_URL - Direct connection (use for Prisma migrations locally)
# Same URL but without the ?authToken query param, or use the HTTP connection
DIRECT_URL="libsql://forge-db-YOURORG.turso.io?authToken=YOUR_TOKEN"

# NextAuth (optional - only if you add auth later)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your-secret-here